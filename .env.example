# ============================================
# STEP 1: SELECT YOUR MODELS
# ============================================
# Set your preferred LLM and embedding models here.
# These will be used as defaults when you create a GraphRAG instance.

# Option A: OpenRouter (Recommended - 10x cheaper than OpenAI)
# ---------------------------------------------------------
LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet
EMBEDDING_MODEL=openrouter/qwen/qwen3-embedding-8b
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Option B: Ollama (Free, Local)
# ----------------------------
# LLM_MODEL=ollama/llama3.2
# EMBEDDING_MODEL=ollama/nomic-embed-text
# No API key needed!

# Option C: OpenAI (Default)
# -------------------------
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=your-openai-api-key-here

# Option D: Anthropic (High Quality)
# ----------------------------------
# LLM_MODEL=claude-3-5-sonnet-20241022
# EMBEDDING_MODEL=voyage-large-2
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# STEP 2: UNDERSTAND MODEL FORMATS
# ============================================
#
# OpenRouter format: "openrouter/<provider>/<model>"
#   Examples:
#   - openrouter/anthropic/claude-3.5-sonnet
#   - openrouter/meta-llama/llama-3.1-70b
#   - openrouter/google/gemini-pro-1.5
#   - openrouter/microsoft/phi-3-medium-128k-instruct
#
# Ollama format: "ollama/<model-name>"
#   Examples:
#   - ollama/llama3.2
#   - ollama/qwen2.5
#   - ollama/nomic-embed-text
#
# Anthropic format: "<model-name>"
#   Examples:
#   - claude-3-5-sonnet-20241022
#   - claude-3-haiku-20240307
#
# OpenAI format: "<model-name>"
#   Examples:
#   - gpt-4o
#   - gpt-4o-mini
#   - text-embedding-3-small
#
# ============================================
# STEP 3: CONFIGURATION NOTES
# ============================================
#
# HOW IT WORKS:
# 1. Set LLM_MODEL and EMBEDDING_MODEL above (choose one option)
# 2. Set the corresponding API key (if needed)
# 3. These models become the DEFAULT for all GraphRAG instances
#
# TO OVERRIDE IN CODE:
# ```python
# from nano_graphrag import GraphRAG
#
# # Use default models from .env
# rag = GraphRAG(working_dir="./dickens")
#
# # Or override specific models
# rag = GraphRAG(
#     working_dir="./dickens",
#     llm_model="ollama/llama3.2",  # Override LLM
#     embedding_model="ollama/nomic-embed-text"  # Override embedding
# )
# ```
#
# TO OVERRIDE IN YAML CONFIGS:
# ```yaml
# graphrag:
#   llm_model: ollama/llama3.2  # Override default
#   embedding_model: ollama/nomic-embed-text
# ```
#
# ============================================
# API KEYS (All Providers)
# ============================================

# OpenRouter (Recommended)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
OPENAI_API_VERSION=2024-02-01

# Google AI / Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Cohere
COHERE_API_KEY=your-cohere-api-key-here

# Hugging Face
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# ============================================
# ADVANCED CONFIGURATION
# ============================================

# Custom API endpoints (if needed)
LLM_API_BASE=
EMBEDDING_API_BASE=

# Entity extraction quality: "fast" | "balanced" | "thorough"
ENTITY_EXTRACTION_QUALITY=balanced

# Graph clustering algorithm
GRAPH_CLUSTER_ALGORITHM=leiden

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# ============================================
# COST COMPARISON (Quick Test - 200 samples)
# ============================================
#
# Provider              | Cost    | Quality
# ---------------------|---------|----------
# Ollama (local)       | FREE    | Medium
# OpenRouter           | ~$0.50  | High
# OpenAI               | ~$5.00  | High
# Anthropic            | ~$3.00  | Very High
#
# RECOMMENDATION: Use OpenRouter for best value!
#
# ============================================
# QUICK SETUP EXAMPLES
# ============================================

# Example 1: OpenRouter (Most Cost-Effective)
# ---------------------------------------------
# Copy this to your .env file:
"""
LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet
EMBEDDING_MODEL=openrouter/qwen/qwen3-embedding-8b
OPENROUTER_API_KEY=sk-or-v1-your-key-here
"""

# Example 2: Ollama (Free)
# -----------------------
# Copy this to your .env file:
"""
LLM_MODEL=ollama/llama3.2
EMBEDDING_MODEL=ollama/nomic-embed-text
# No API key needed!
"""

# Example 3: Mix and Match
# -----------------------
# Use OpenRouter for LLM, Ollama for embeddings:
"""
LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet
EMBEDDING_MODEL=ollama/nomic-embed-text
OPENROUTER_API_KEY=sk-or-v1-your-key-here
"""

# ============================================
# MODEL RECOMMENDATIONS
# ============================================

# For Development (Cheap & Fast):
# LLM_MODEL=openrouter/microsoft/phi-3-medium-128k-instruct
# EMBEDDING_MODEL=openrouter/qwen/qwen3-embedding-8b

# For Production (Quality & Value):
# LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet
# EMBEDDING_MODEL=openrouter/qwen/qwen3-embedding-8b

# For Best Quality (Budget Allowed):
# LLM_MODEL=claude-3-5-sonnet-20241022
# EMBEDDING_MODEL=voyage-large-2

# For Local (Free):
# LLM_MODEL=ollama/llama3.2
# EMBEDDING_MODEL=ollama/nomic-embed-text

# ============================================
# TROUBLESHOOTING
# ============================================

# Issue: "Model not found"
# Solution: Check model format at https://openrouter.ai/docs#models
#          Use format: "openrouter/<provider>/<model>"

# Issue: "API key not found"
# Solution: Make sure you uncommented (removed #) from your chosen option
#          and added your actual API key

# Issue: "Want to use different models for different projects"
# Solution: Don't set LLM_MODEL in .env. Instead, specify models
#          in your YAML configs or when creating GraphRAG instances
